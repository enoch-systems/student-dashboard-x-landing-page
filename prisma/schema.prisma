generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  course        String

  dateJoined    DateTime @default(now())
  paymentStatus String   @default("Not paid")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}